{
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.16.0",
    "npm": ">=10.9.2"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:vite": "vite --host --mode development",
    "prod": "cross-env NODE_ENV=production vite --host --mode production",
    "build": "rm -rf dist && vite build --mode development",
    "build:prod": "rm -rf dist && cross-env NODE_ENV=production vite build --mode production",
    "preview": "vite preview",
    "deploy": "bun run build:prod && wrangler deploy",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "lint": "eslint \"src/**/*.{ts,tsx,md}\" --ext .ts,.tsx",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,md}\" --ext .ts,.tsx --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,md}\"",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint && bun run test && bun run build:prod",
    "check:ci": "bun run check && bun audit --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@tanstack/react-query": "^5.90.21",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-table-of-contents": "^1.1.0",
    "preact": "^10.29.0",
    "preact-iso": "^2.11.1",
    "preact-render-to-string": "^6.6.6",
    "react-helmet-async": "^3.0.0",
    "rollup": "^4.59.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@preact/preset-vite": "^2.10.3",
    "@testing-library/preact": "^3.2.4",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "semver": "^7.6.3",
    "undici": "^7.18.2",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23"
  }
}
